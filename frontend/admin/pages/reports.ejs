                showToast('Failed to generate report', 'error');
            }
        }

        function buildBarChart(canvasId, labels, values, color) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const W = canvas.width, H = canvas.height;
            const P = { t: 12, r: 10, b: 30, l: 52 };
            const cW = W - P.l - P.r, cH = H - P.t - P.b;
            ctx.clearRect(0, 0, W, H);

            const max  = Math.max(...values, 1);
            const barW = Math.max(5, (cW / values.length) - 5);

            // Grid lines
            [0.25, 0.5, 0.75, 1].forEach(f => {
                const y = P.t + cH * (1 - f);
                ctx.strokeStyle = '#e2e8f0'; ctx.lineWidth = 0.8;
                ctx.setLineDash([3, 3]);
                ctx.beginPath(); ctx.moveTo(P.l, y); ctx.lineTo(W - P.r, y); ctx.stroke();
                ctx.setLineDash([]);
                ctx.fillStyle = '#94a3b8'; ctx.font = '9px system-ui';
                ctx.textAlign = 'right';
                ctx.fillText(fmtK(max * f), P.l - 4, y + 3);
            });

            // Baseline
            ctx.strokeStyle = '#cbd5e1'; ctx.lineWidth = 1; ctx.setLineDash([]);
            ctx.beginPath();
            ctx.moveTo(P.l, P.t + cH); ctx.lineTo(W - P.r, P.t + cH);
            ctx.stroke();

            // Bars
            values.forEach((v, i) => {
                const x  = P.l + i * (cW / values.length) + (cW / values.length - barW) / 2;
                const bH = (v / max) * cH;
                const y  = P.t + cH - bH;
                const g  = ctx.createLinearGradient(x, y, x, y + bH);
                g.addColorStop(0, color);
                g.addColorStop(1, color + '44');
                ctx.fillStyle = g;
                ctx.beginPath();
                if (ctx.roundRect) ctx.roundRect(x, y, barW, bH, [3, 3, 0, 0]);
                else ctx.rect(x, y, barW, bH);
                ctx.fill();
                if (labels[i]) {
                    ctx.fillStyle = '#64748b'; ctx.font = '8px system-ui';
                    ctx.textAlign = 'center';
                    ctx.fillText(labels[i].slice(0, 5), x + barW / 2, H - 8);
                }
            });
        }

        function buildDonut(canvasId, labels, values, colors) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const W = canvas.width, H = canvas.height;
            const cx = W / 2, cy = H / 2;
            const outer = Math.min(W, H) / 2 - 6;
            const inner = outer * 0.56;
            const total = values.reduce((a, b) => a + b, 0) || 1;
            ctx.clearRect(0, 0, W, H);
            let a = -Math.PI / 2;
            values.forEach((v, i) => {
                const sw = (v / total) * 2 * Math.PI;
                ctx.beginPath(); ctx.moveTo(cx, cy);
                ctx.arc(cx, cy, outer, a, a + sw);
                ctx.closePath(); ctx.fillStyle = colors[i % colors.length]; ctx.fill();
                a += sw;
            });
            ctx.beginPath(); ctx.arc(cx, cy, inner, 0, 2 * Math.PI);
            ctx.fillStyle = '#fff'; ctx.fill();
            ctx.fillStyle = '#1e293b'; ctx.font = 'bold 10px system-ui';
            ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
            ctx.fillText(values.length + ' pkgs', cx, cy);
        }

