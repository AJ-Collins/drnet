        async function saveGeneralReportEdit(id) {
            const updatedData = {
                report_date: allReports.find(r => r.id === id).report_date,
                ops_summary: document.getElementById('edit_ops_summary').value,
                ops_installs: parseInt(document.getElementById('edit_ops_installs').value) || 0,
                ops_pending: parseInt(document.getElementById('edit_ops_pending').value) || 0,
                staff_summary: document.getElementById('edit_staff_summary').value,
                support_summary: document.getElementById('edit_support_summary').value,
                is_urgent: document.getElementById('edit_is_urgent').checked ? 1 : 0,
                conclusion: document.getElementById('edit_conclusion').value,
                status: document.getElementById('edit_status').value
            };

            try {
                const response = await fetch(`/api/reports/general/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(updatedData)
                });

                const data = await response.json();

                if (data.success) {
                    showToast('Report updated successfully', 'success');
                    fetchGeneralReports();
                } else {
                    showToast('Failed to update report', 'error');
                }
            } catch (error) {
                console.error('Error updating report:', error);
                showToast('Failed to update report', 'error');
            }
        }

        async function deleteGeneralReport(id) {
            if (!confirm('Are you sure you want to delete this report? This action cannot be undone.')) {
                return;
            }

            try {
                const response = await fetch(`/api/reports/general/${id}`, {
                    method: 'DELETE'
                });

                const data = await response.json();

                if (data.success) {
                    showToast('Report deleted successfully', 'success');
                    fetchGeneralReports();
                } else {
                    showToast('Failed to delete report', 'error');
                }
            } catch (error) {
                console.error('Error deleting report:', error);
                showToast('Failed to delete report', 'error');
            }
        }

        function addPdfHeader(doc, subtitle) {
            const W = doc.internal.pageSize.getWidth();

            // Brand name
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(9.5);
            doc.setTextColor(...BRAND.color);
            doc.text(BRAND.name, 14, 10);

            // Tagline
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(5.8);
            doc.text(BRAND.tagline, W - 14, 10, { align: 'right' });

            // Thin divider line
            doc.setDrawColor(...BRAND.color);
            doc.setLineWidth(0.3);
            doc.line(0, 14, W, 14);

            // Subtitle
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(11);
            doc.setTextColor(...BRAND.dark);
            doc.text(subtitle, 14, 22);

            // Reset text color
            doc.setTextColor(0, 0, 0);

            return 28;
        }

        function addPdfFooter(doc) {
            const n = doc.internal.getNumberOfPages();
            const W = doc.internal.pageSize.getWidth();
            const H = doc.internal.pageSize.getHeight();
            for (let i = 1; i <= n; i++) {
                doc.setPage(i);
                doc.setDrawColor(180, 180, 180);
                doc.setLineWidth(0.3);
                doc.line(14, H - 11, W - 14, H - 11);
                doc.setFont('helvetica', 'normal');
                doc.setFontSize(7);
                doc.setTextColor(140, 140, 140);
                doc.text(BRAND.name + '  —  Confidential', 14, H - 6);
                doc.text(`Page ${i} of ${n}`, W - 14, H - 6, { align: 'right' });
            }
        }

        function fmt(n)  { return Number(n || 0).toLocaleString(); }
        function fmtK(n) { const v = Number(n||0); return v >= 1000 ? (v/1000).toFixed(1)+'K' : String(v); }
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        async function downloadGeneralReportPDF(id) {
            const report = allReports.find(r => r.id === id);
            if (!report) return;

            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            const W   = doc.internal.pageSize.getWidth();

            let y = addPdfHeader(doc, 'Daily General Report');

            // Meta
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8.5);
            doc.setTextColor(80, 80, 80);
            doc.text(`Report #${report.id}   |   Date: ${new Date(report.report_date).toLocaleDateString()}`, 14, y);
            doc.text(`Prepared by: ${report.first_name} ${report.second_name}  —  ${report.position||''}`, 14, y + 5);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(...BRAND.dark);
            doc.text(`Status: ${(report.status||'').toUpperCase()}     Priority: ${report.is_urgent ? 'URGENT' : 'NORMAL'}`, 14, y + 10);
            doc.setTextColor(0, 0, 0);
            y += 17;

            // Section builder
            function genSection(title, body, extraFn) {
                if (y > 242) { doc.addPage(); y = addPdfHeader(doc, 'Daily General Report (cont.)') + 4; }

                // Heavy rule + caps, no color
                doc.setDrawColor(15, 23, 42); doc.setLineWidth(0.6);
                doc.line(14, y, W - 14, y);
                doc.setFont('helvetica', 'bold'); doc.setFontSize(8.5); doc.setTextColor(15, 23, 42);
                doc.text(title.toUpperCase(), 14, y + 5.5);
                doc.setDrawColor(200, 200, 200); doc.setLineWidth(0.25);
                doc.line(14, y + 7, W - 14, y + 7);
                doc.setTextColor(0, 0, 0);
                y += 12;

                doc.setFont('helvetica', 'normal'); doc.setFontSize(9); doc.setTextColor(50, 50, 50);
                const lines = doc.splitTextToSize(body || 'No summary provided.', W - 28);
                doc.text(lines, 14, y);
                y += lines.length * 5 + 4;
                if (extraFn) extraFn();
                y += 5;
            }

            genSection('Operations & Logistics', report.ops_summary, () => {
                if (y > 250) { doc.addPage(); y = addPdfHeader(doc, 'Daily General Report (cont.)') + 4; }
                const bW = (W - 32) / 2;

                // Stat boxes — white fill, hairline border, dark text
                doc.setFillColor(255, 255, 255);
                doc.setDrawColor(170, 170, 170); doc.setLineWidth(0.4);
                doc.rect(14, y, bW - 2, 13, 'FD');
                doc.setFont('helvetica', 'bold'); doc.setFontSize(7); doc.setTextColor(100, 100, 100);
                doc.text('INSTALLATIONS', 16, y + 5);
                doc.setFontSize(14); doc.setTextColor(15, 23, 42);
                doc.text(String(report.ops_installs || 0), 16, y + 11.5);

                doc.rect(14 + bW + 2, y, bW - 2, 13, 'FD');
                doc.setFontSize(7); doc.setTextColor(100, 100, 100);
                doc.text('PENDING JOBS', 16 + bW + 2, y + 5);
                doc.setFontSize(14); doc.setTextColor(15, 23, 42);
                doc.text(String(report.ops_pending || 0), 16 + bW + 2, y + 11.5);

                doc.setTextColor(0, 0, 0); y += 17;
            });

            genSection('Staff & Personnel',         report.staff_summary);
            genSection('Support & Client Feedback', report.support_summary);

            // Conclusion — dark left rule (not brand color)
            if (y > 232) { doc.addPage(); y = addPdfHeader(doc, 'Daily General Report (cont.)') + 4; }
            doc.setDrawColor(15, 23, 42); doc.setLineWidth(0.6);
            doc.line(14, y, W - 14, y);
            doc.setFont('helvetica', 'bold'); doc.setFontSize(8.5); doc.setTextColor(15, 23, 42);
            doc.text('CONCLUSION & ACTION ITEMS', 14, y + 5.5);
            doc.setDrawColor(200, 200, 200); doc.setLineWidth(0.25);
            doc.line(14, y + 7, W - 14, y + 7);
            y += 12;

            const cLines = doc.splitTextToSize(report.conclusion || 'No conclusion provided.', W - 34);
            // Dark left accent rule
            doc.setFillColor(15, 23, 42);
            doc.rect(14, y - 2, 2, cLines.length * 5 + 4, 'F');
            doc.setFont('helvetica', 'normal'); doc.setFontSize(9); doc.setTextColor(50, 50, 50);
            doc.text(cLines, 20, y);

            addPdfFooter(doc);
            doc.save(`Report-${report.id}-${report.report_date}.pdf`);
            showToast('PDF downloaded successfully', 'success');
        }

