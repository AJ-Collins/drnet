                </div>`;

            const perfRow = (dot, label, value) => `
                <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #f3f4f6;font-size:11px">
                    <div style="width:7px;height:7px;border-radius:50%;background:${dot};flex-shrink:0"></div>
                    <span style="font-weight:500;color:#374151;flex:1">${label}</span>
                    <span style="font-weight:700;color:#111827">${value}</span>
                </div>`;

            let html = `
            <style>
                .isp { font-family:'Plus Jakarta Sans',sans-serif;color:#111827;line-height:1.4 }
                .isp table { width:100%;border-collapse:collapse }
                .isp canvas { display:block;width:100%!important }
                .isp-two { display:grid;grid-template-columns:1fr 1fr;gap:14px }
                .isp-chart { border:1px solid #e5e7eb;padding:12px }
                .isp-chart-lbl { font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 8px }
            </style>
            <div class="isp">

            <div style="padding-bottom:10px;margin-bottom:18px">
                <div style="display:flex;justify-content:space-between;align-items:flex-end">
                    <div>
                        <p style="font-size:17px;font-weight:900;letter-spacing:0.02em;color:#111827;margin:0 0 2px;text-transform:uppercase">DR.NET Technology Labs</p>
                        <p style="font-size:9px;font-weight:600;letter-spacing:0.09em;color:#6b7280;text-transform:uppercase;margin:0">Innovative Connections With Doctors Precision</p>
                    </div>
                    <div style="text-align:right">
                        <p style="font-size:12px;font-weight:800;color:#111827;margin:0">Performance Report</p>
                        <p style="font-size:9px;color:#6b7280;margin:3px 0 0">${meta.period_label}</p>
                    </div>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:18px;margin-top:8px;padding-top:7px;border-top:1px solid #e5e7eb">
                    <span style="font-size:9px;color:#6b7280"><b style="color:#111827">Period:</b> ${meta.period_start} – ${meta.period_end}</span>
                    <span style="font-size:9px;color:#6b7280"><b style="color:#111827">Generated:</b> ${new Date(meta.generated_at).toLocaleString()}</span>
                    <span style="font-size:9px;color:#6b7280"><b style="color:#111827">Report Type:</b> ${meta.report_type.toUpperCase()}</span>
                </div>
            </div>`;

            if (financial) {
                const trend      = financial.revenue_trend_pct;
                const trendColor = trend >= 0 ? CHART.green : CHART.red;
                const trendArrow = trend >= 0 ? '▲' : '▼';
                const dailyVals  = (charts?.daily_revenue || []).map(d => Number(d.total_revenue));

                html += sec(1, 'Financial Performance');

                html += factGrid([
                    ['Total Revenue',      'KES ' + fmt(financial.total_revenue)],
                    ['Net Profit',         'KES ' + fmt(financial.net_profit)],
                    ['Profit Margin',      financial.profit_margin_pct + '%'],
                    ['Subscription Rev.',  'KES ' + fmt(financial.subscription_revenue)],
                    ['Sales Revenue',      'KES ' + fmt(financial.sales_revenue)],
                    ['Expenditure',        'KES ' + fmt(financial.monthly_expenditure)],
                    ['Staff Salaries',     'KES ' + fmt(financial.staff_salaries_payable)],
                    ['Previous Period',    'KES ' + fmt(financial.prev_period_revenue)],
                    ['Revenue Trend',      `<span style="color:${trendColor};font-weight:800">${trendArrow} ${Math.abs(trend)}%</span>`],
                ]);

                if (dailyVals.length) {
                    html += `
                    <div class="isp-chart" style="margin-bottom:14px">
                        <p class="isp-chart-lbl">Daily Revenue Trend — ${meta.period_label} (KES)</p>
                        <canvas id="chartRevDaily" height="120"></canvas>
                    </div>`;
                }

                if (financial.expense_breakdown?.length) {
                    html += `<div style="margin-bottom:14px">
                        <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 8px">Expenditure by Category</p>`;
                    const maxE = Math.max(...financial.expense_breakdown.map(e => Number(e.total_amount)));
                    financial.expense_breakdown.forEach(e => {
                        const pct = Math.round((Number(e.total_amount)/maxE)*100);
                        html += `
                        <div style="display:flex;align-items:center;padding:5px 0;border-bottom:1px solid #f3f4f6;font-size:11px;gap:8px">
                            <span style="font-weight:500;color:#374151;width:130px;flex-shrink:0">${escapeHtml(e.category||'Other')}</span>
                            <div style="flex:1;height:4px;background:#f3f4f6;border-radius:2px;overflow:hidden">
                                <div style="height:100%;width:${pct}%;background:${CHART.red};border-radius:2px"></div>
                            </div>
                            <span style="font-weight:700;color:#111827;white-space:nowrap;min-width:90px;text-align:right">KES ${fmt(e.total_amount)}</span>
                        </div>`;
                    });
                    html += `</div>`;
                }
            }

            if (clients) {
                const total       = clients.total_users || 1;
                const activePct   = Math.round((clients.active_subscriptions / total) * 100);
                const expiredPct  = Math.round((clients.expired_users        / total) * 100);
                const inactivePct = Math.round((clients.inactive_users       / total) * 100);

                html += sec(2, 'Client Overview');

                html += factGrid([
                    ['Total Users',       clients.total_users],
                    ['Active Subs',       clients.active_subscriptions],
                    ['New (Period)',       clients.new_clients_period],
                    ['Expired',           clients.expired_users],
                    ['Expiring ≤5 Days',  clients.overdue_users],
                    ['No Subscription',   clients.inactive_users],
                ]);

                html += `
                <div style="margin-bottom:14px">
                    <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 5px">Subscription Health</p>
                    <div style="display:flex;height:7px;border-radius:3px;overflow:hidden;border:1px solid #e5e7eb">
                        <div style="width:${activePct}%;background:${CHART.green}"></div>
                        <div style="width:${expiredPct}%;background:${CHART.red}"></div>
                        <div style="width:${inactivePct}%;background:#d1d5db"></div>
                    </div>
                    <div style="display:flex;gap:16px;margin-top:5px">
                        <span style="font-size:9px;font-weight:600;color:${CHART.green}">● Active ${activePct}%</span>
                        <span style="font-size:9px;font-weight:600;color:${CHART.red}">● Expired ${expiredPct}%</span>
                        <span style="font-size:9px;font-weight:600;color:#9ca3af">● No Sub ${inactivePct}%</span>
                    </div>
                </div>`;

                if (clients.package_popularity?.length) {
                    html += `
                    <div class="isp-two" style="margin-bottom:14px">
                        <div class="isp-chart">
                            <p class="isp-chart-lbl">Top Packages — Active Subscriptions</p>
                            <canvas id="chartPkgBar" height="110"></canvas>
                        </div>
                        <div class="isp-chart">
                            <p class="isp-chart-lbl">Package Distribution</p>
                            <canvas id="chartPkgDonut" height="90"></canvas>
                            <div style="margin-top:8px">
                                ${clients.package_popularity.slice(0,5).map((p,i) => `
                                <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px">
                                    <div style="width:8px;height:8px;border-radius:2px;background:${CHART.pkg[i]};flex-shrink:0"></div>
                                    <span style="font-size:9px;color:#374151;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(p.package_name)}</span>
                                    <span style="font-size:9px;font-weight:700;color:#111827">${p.subscription_count}</span>
                                </div>`).join('')}
                            </div>
                        </div>
                    </div>`;
                }
            }

            if (operations) {
                const bookPct = operations.bookings_in_period > 0
                    ? Math.round((operations.bookings_completed / operations.bookings_in_period) * 100) : 0;

                html += sec(3, 'Operations & Field Activity');

                html += factGrid([
                    ['Bookings (Period)',  operations.bookings_in_period],
                    ['Completed',         operations.bookings_completed],
                    ['Pending Bookings',  operations.pending_bookings],
                    ['Open Tickets',      operations.pending_tickets],
                    ['Resolved (Period)', operations.resolved_tickets_period],
                    ['Pending Tasks',     operations.pending_tasks],
                    ['Tasks Done',        operations.completed_tasks_period],
                    ['Staff on Duty',     operations.staff_on_duty_today],
                    ['Inventory Value',   'KES ' + fmt(operations.inventory_value)],
                ]);

                html += `
                <div style="margin-bottom:14px">
                    <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 5px">Booking Completion Rate</p>
                    <div style="height:6px;background:#f3f4f6;border-radius:3px;overflow:hidden;border:1px solid #e5e7eb">
                        <div style="height:100%;width:${bookPct}%;background:${CHART.green};border-radius:3px"></div>
                    </div>
                    <p style="font-size:9px;color:#6b7280;margin:4px 0 0">${bookPct}% completed (${operations.bookings_completed} of ${operations.bookings_in_period} bookings)</p>
                </div>`;

                html += `
                <div class="isp-two" style="margin-bottom:14px">
                    <div>
                        <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 6px">Inventory Status</p>
                        ${perfRow(CHART.green,  'In Stock',      operations.in_stock_items + ' items')}
                        ${perfRow(CHART.red,    'Out of Stock',  operations.out_of_stock_items + ' items')}
                        ${perfRow(CHART.purple, 'Total Value',   'KES ' + fmt(operations.inventory_value))}
                    </div>
                    <div>
                        <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 6px">Support & Staff</p>
                        ${perfRow(CHART.red,   'Open Tickets',   operations.pending_tickets)}
                        ${perfRow(CHART.green, 'Resolved',       operations.resolved_tickets_period)}
                        ${perfRow('#9ca3af',   'Staff on Duty',  operations.staff_on_duty_today + ' today')}
                    </div>
                </div>`;

                if (operations.sales_by_category?.length) {
                    html += `<div style="margin-bottom:14px">
                        <p style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#6b7280;margin:0 0 6px">Sales by Product Category</p>`;
                    const maxS = Math.max(...operations.sales_by_category.map(s => Number(s.total_revenue)));
                    operations.sales_by_category.forEach(s => {
                        const pct = Math.round((Number(s.total_revenue)/maxS)*100);
                        html += `
                        <div style="display:flex;align-items:center;padding:5px 0;border-bottom:1px solid #f3f4f6;font-size:11px;gap:8px">
                            <span style="font-weight:500;color:#374151;width:130px;flex-shrink:0">${escapeHtml(s.category||'Other')}</span>
                            <span style="font-size:9px;color:#9ca3af;white-space:nowrap">${s.sales_count} sales</span>
                            <div style="flex:1;height:4px;background:#f3f4f6;border-radius:2px;overflow:hidden">
                                <div style="height:100%;width:${pct}%;background:${CHART.blue};border-radius:2px"></div>
                            </div>
                            <span style="font-weight:700;color:#111827;white-space:nowrap;min-width:90px;text-align:right">KES ${fmt(s.total_revenue)}</span>
                        </div>`;
                    });
                    html += `</div>`;
                }
            }

            html += `
                <div style="border-top:1px solid #d1d5db;margin-top:24px;padding-top:8px;display:flex;justify-content:space-between">
                    <span style="font-size:9px;color:#9ca3af">${BRAND.name}</span>
                    <span style="font-size:9px;color:#9ca3af">Confidential — Internal Use Only</span>
                </div>
            </div>`; // .isp

            preview.innerHTML = html;

            requestAnimationFrame(() => {
                ['chartRevDaily','chartPkgBar','chartPkgDonut'].forEach(id => {
                    const c = document.getElementById(id);
                    if (c) c.width = c.offsetWidth || 300;
                });
                if (charts?.daily_revenue?.length) {
                    buildBarChart('chartRevDaily',
                        charts.daily_revenue.map(d => d.day_label),
                        charts.daily_revenue.map(d => Number(d.total_revenue)),
                        CHART.pink
                    );
                }
                if (clients?.package_popularity?.length) {
                    const pkgs = clients.package_popularity;
                    buildBarChart('chartPkgBar',  pkgs.map(p=>p.package_name), pkgs.map(p=>p.subscription_count), CHART.pink);
                    buildDonut('chartPkgDonut',   pkgs.map(p=>p.package_name), pkgs.map(p=>p.subscription_count), CHART.pkg);
                }
            });
        }

        function generateAnalyticsPDF(data) {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            const { meta, financial, clients, operations } = data;
            const W = doc.internal.pageSize.getWidth();

            let y = addPdfHeader(doc, 'Analytics Report');

            // Report meta — plain text
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8.5);
            doc.setTextColor(80, 80, 80);
            doc.text(`Period:      ${meta.period_label}  (${meta.period_start})`, 14, y);
            doc.text(`Generated:   ${new Date(meta.generated_at).toLocaleString()}`, 14, y + 5);
            doc.text(`Report Type: ${meta.report_type.toUpperCase()}`, 14, y + 10);
            y += 17;

            function pdfSection(title) {
                if (y > 245) { doc.addPage(); y = addPdfHeader(doc, 'Performance Report (cont.)') + 4; }
                doc.setDrawColor(15, 23, 42);
                doc.setLineWidth(0.6);
                doc.line(14, y, W - 14, y);
                doc.setFont('helvetica', 'bold');
                doc.setFontSize(8.5);
                doc.setTextColor(15, 23, 42);
                doc.text(title.toUpperCase(), 14, y + 5.5);
                doc.setDrawColor(200, 200, 200);
                doc.setLineWidth(0.25);
                doc.line(14, y + 7, W - 14, y + 7);
                doc.setTextColor(0, 0, 0);
                y += 12;
            }

            function pdfTable(head, rows, colStyles) {
                if (y > 238) { doc.addPage(); y = addPdfHeader(doc, 'Performance Report (cont.)') + 4; }
                doc.autoTable({
                    startY: y,
                    head: [head],
                    body: rows,
                    theme: 'grid',
                    headStyles: {
                        fillColor:   [15, 23, 42],
                        textColor:   [255, 255, 255],
                        fontSize:    8,
                        fontStyle:   'bold',
                        cellPadding: 3,
                    },
                    bodyStyles: {
                        fillColor:   [255, 255, 255],   // pure white — no color
                        textColor:   [30, 30, 30],
                        fontSize:    8.5,
                        cellPadding: 3,
                    },
                    alternateRowStyles: {
                        fillColor: [250, 250, 250],     // barely-off-white
                    },
                    columnStyles: colStyles || {},
                    margin: { left: 14, right: 14 },
                    tableLineColor: [200, 200, 200],
                    tableLineWidth: 0.2,
                });
                y = doc.lastAutoTable.finalY + 8;
            }

            if (financial) {
                pdfSection('1. Financial Performance');
                pdfTable(
                    ['Metric', 'This Period', 'Prev Period', 'Change'],
                    [
                        ['Total Revenue',          'KES '+fmt(financial.total_revenue),         'KES '+fmt(financial.prev_period_revenue), (financial.revenue_trend_pct>=0?'+':'')+financial.revenue_trend_pct+'%'],
                        ['Subscription Revenue',   'KES '+fmt(financial.subscription_revenue),  '—', '—'],
                        ['Sales Revenue',          'KES '+fmt(financial.sales_revenue),          '—', '—'],
                        ['Total Expenditure',      'KES '+fmt(financial.monthly_expenditure),    '—', '—'],
                        ['Net Profit',             'KES '+fmt(financial.net_profit),             '—', financial.profit_margin_pct+'% margin'],
                        ['Staff Salaries Payable', 'KES '+fmt(financial.staff_salaries_payable), '—', '—'],
                    ],
                    { 0:{cellWidth:58}, 3:{cellWidth:26} }
                );

                if (financial.expense_breakdown?.length) {
                    pdfSection('Expenditure Breakdown');
                    pdfTable(
                        ['Category', 'Transactions', 'Amount (KES)'],
                        financial.expense_breakdown.map(e => [
                            e.category||'Other', e.transaction_count, fmt(e.total_amount)
                        ]),
                        { 0:{cellWidth:85}, 2:{cellWidth:44} }
                    );
                }
            }

            if (clients) {
                pdfSection('2. Client Overview');
                const total = clients.total_users || 1;
                pdfTable(
                    ['Metric', 'Count', '% of Users'],
                    [
                        ['Total Registered Users',  clients.total_users,         '100%'],
                        ['Active Subscriptions',    clients.active_subscriptions, Math.round(clients.active_subscriptions/total*100)+'%'],
                        ['New Clients (Period)',     clients.new_clients_period,   '—'],
                        ['Expired Subscriptions',   clients.expired_users,        Math.round(clients.expired_users/total*100)+'%'],
                        ['Expiring in ≤5 Days',     clients.overdue_users,        '—'],
                        ['No Subscription',         clients.inactive_users,       Math.round(clients.inactive_users/total*100)+'%'],
                    ],
                    { 0:{cellWidth:85}, 2:{cellWidth:30} }
                );

                if (clients.package_popularity?.length) {
                    pdfSection('Active Subscription Packages');
                    pdfTable(
                        ['Package Name', 'Speed', 'Price (KES)', 'Active Subs'],
                        clients.package_popularity.map(p => [
                            p.package_name, p.speed||'—', fmt(p.price), p.subscription_count
                        ]),
                        { 0:{cellWidth:65} }
                    );
                }
            }

            if (operations) {
                pdfSection('3. Operations Summary');
                const bookPct = operations.bookings_in_period > 0
                    ? Math.round(operations.bookings_completed/operations.bookings_in_period*100) : 0;
                pdfTable(
                    ['Metric', 'Value', 'Notes'],
                    [
                        ['Bookings in Period',         operations.bookings_in_period,      bookPct+'% completed'],
                        ['Pending Bookings',           operations.pending_bookings,        'Requires action'],
                        ['Open Support Tickets',       operations.pending_tickets,         'In queue'],
                        ['Tickets Resolved (Period)',  operations.resolved_tickets_period, '—'],
                        ['Pending Staff Tasks',        operations.pending_tasks,           'Active assignments'],
                        ['Tasks Completed (Period)',   operations.completed_tasks_period,  '—'],
                        ['Inventory Value',            'KES '+fmt(operations.inventory_value), operations.in_stock_items+' in / '+operations.out_of_stock_items+' out'],
                        ['Staff On Duty Today',        operations.staff_on_duty_today,     '—'],
                    ],
                    { 0:{cellWidth:68}, 2:{cellWidth:46} }
                );

                if (operations.sales_by_category?.length) {
                    pdfSection('Sales by Product Category');
                    pdfTable(
                        ['Category', 'Sales Count', 'Revenue (KES)'],
                        operations.sales_by_category.map(s => [
                            s.category||'Other', s.sales_count, fmt(s.total_revenue)
                        ]),
                        { 0:{cellWidth:85}, 2:{cellWidth:44} }
                    );
                }
            }

            addPdfFooter(doc);
            doc.save(`DR.NET-Performance-Report-${meta.period_start}-to-${meta.period_end}.pdf`);
            showToast('PDF downloaded successfully', 'success');
        }

        function downloadCurrentReport() {
            if (!currentAnalyticsData) { showToast('No report to download', 'error'); return; }
            generateAnalyticsPDF(currentAnalyticsData);
        }

        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `px-6 py-3 rounded-lg shadow-lg text-white text-sm font-bold animate-fade-in ${
                type === 'success' ? 'bg-emerald-600' : 
                type === 'error' ? 'bg-red-600' : 
                'bg-blue-600'
            }`;
            toast.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'} mr-2"></i>
                ${message}
            `;
            
            document.getElementById('toastContainer').appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }        
    </script>