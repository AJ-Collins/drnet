            const customYear  = document.getElementById('customYear')?.value;
            const customMonth = document.getElementById('customMonth')?.value;

            const params = new URLSearchParams({ period, report_type: reportType });

            if (period === 'custom') {
                const isRange = document.getElementById('modeRange')?.checked;
                if (isRange && dateFrom && dateTo) {
                    params.set('date_from', dateFrom);
                    params.set('date_to', dateTo);
                } else if (customYear && customMonth) {
                    params.set('year', customYear);
                    params.set('month', customMonth);
